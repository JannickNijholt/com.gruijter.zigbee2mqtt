{
  "title": {
    "en": "Set serving size"
  },
  "titleFormatted": {
    "en": "Set serving size to [[val]]"
  },
  "highlight": true,
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=device|group&capabilities=custom_number.serving_size"
    },
    {
      "name": "val",
      "type": "range",
      "min": 1,
      "max": 10,
      "step": 1,
      "value": 1,
      "label": "portion",
      "labelDecimals": 0
    }
  ]
}
